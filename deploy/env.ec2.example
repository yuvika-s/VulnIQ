# Copy to /opt/vulniq/backend/.env on the EC2 instance and fill in YOUR values.
# DATABASE_URL is intentionally NOT set — it is assembled in code from the
# Secrets Manager secret below (username/password) + DB_HOST/DB_NAME.
# This file is a TEMPLATE — never put real secrets here; the on-instance .env
# (which holds these values) is gitignored.

# --- RDS via AWS Secrets Manager (read-only fetch) ---
DB_SECRET_ARN=arn:aws:secretsmanager:<region>:<account-id>:secret:<your-rds-secret>
DB_HOST=<your-rds-endpoint>.rds.amazonaws.com
DB_PORT=5432
DB_NAME=vulniq
AWS_REGION=<your-region>

# --- Snyk Enterprise (optional) ---
SNYK_API_TOKEN=
SNYK_ORG_ID=
SNYK_REGION_BASE=https://api.us.snyk.io/rest
SNYK_LOOKBACK_DAYS=30

# --- Tenable Security Center / Tenable.sc (optional) ---
# On-prem SC presents a self-signed cert, so leave TENABLE_VERIFY_SSL=false
# unless your SC has a CA-signed certificate.
TENABLE_BASE_URL=
TENABLE_ACCESS_KEY=
TENABLE_SECRET_KEY=
TENABLE_VERIFY_SSL=false
# Medium included by default — Medium findings are common chain pivots, and the
# connector reserves a per-severity quota so they aren't crowded out.
TENABLE_SEVERITY=critical,high,medium
TENABLE_MAX_FINDINGS=1500

# --- LLM gateway (optional) ---
ANTHROPIC_BASE_URL=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-8
